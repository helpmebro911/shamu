{
  "name": "@shamu/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shamu web dashboard — local-only Hono + SolidJS SPA for swarm overview + run detail with SSE live tail.",
  "main": "./src/server/index.ts",
  "exports": {
    ".": "./src/server/index.ts",
    "./server": "./src/server/index.ts"
  },
  "scripts": {
    "dev": "bun run build:client && bun --hot src/server/index.ts",
    "build": "bun run build:client",
    "build:client": "bun scripts/build-client.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@shamu/adapter-amp": "workspace:*",
    "@shamu/adapter-claude": "workspace:*",
    "@shamu/adapter-codex": "workspace:*",
    "@shamu/adapter-cursor": "workspace:*",
    "@shamu/adapter-echo": "workspace:*",
    "@shamu/adapter-gemini": "workspace:*",
    "@shamu/adapter-opencode": "workspace:*",
    "@shamu/adapter-pi": "workspace:*",
    "@shamu/adapters-base": "workspace:*",
    "@shamu/core-composition": "workspace:*",
    "@shamu/egress-broker": "workspace:*",
    "@shamu/persistence": "workspace:*",
    "@shamu/shared": "workspace:*",
    "@solidjs/router": "0.16.1",
    "hono": "4.12.14",
    "solid-js": "1.9.12",
    "zod": "4.1.13"
  },
  "devDependencies": {
    "bun-plugin-solid": "1.0.0"
  }
}
