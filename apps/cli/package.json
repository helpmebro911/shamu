{
  "name": "@shamu/cli",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Shamu CLI — headless, scriptable entry point for the orchestrator. Commands scaffold the surface; wiring to supervisor/persistence/adapters lands in later phases.",
  "bin": {
    "shamu": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "shamu": "bun src/index.ts",
    "build": "tsc --project tsconfig.build.json",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "clean": "rm -rf dist coverage .turbo"
  },
  "dependencies": {
    "@shamu/adapter-claude": "workspace:*",
    "@shamu/adapter-codex": "workspace:*",
    "@shamu/adapter-echo": "workspace:*",
    "@shamu/adapters-base": "workspace:*",
    "@shamu/core-composition": "workspace:*",
    "@shamu/core-flow": "workspace:*",
    "@shamu/core-supervisor": "workspace:*",
    "@shamu/linear-client": "workspace:*",
    "@shamu/linear-integration": "workspace:*",
    "@shamu/linear-webhook": "workspace:*",
    "@shamu/persistence": "workspace:*",
    "@shamu/shared": "workspace:*",
    "@shamu/watchdog": "workspace:*",
    "@shamu/web": "workspace:*",
    "citty": "0.1.6",
    "zod": "4.1.13"
  }
}
