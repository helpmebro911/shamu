{
  "name": "@shamu/smoketest",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Toolchain canary — replaced in Track 1.B. Proves lint+typecheck+test all work end-to-end.",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
