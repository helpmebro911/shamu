{
  "name": "@shamu/worktree",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Per-run git worktree lifecycle for Shamu: create, destroy, GC, and lease-aware pre-commit hook installer.",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
