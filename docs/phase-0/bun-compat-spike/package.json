{
  "name": "shamu-bun-compat-spike",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Phase 0.A — Bun kill-switch validation harness",
  "scripts": {
    "test:jsonl:bun": "bun src/jsonl-consumer-bun.ts",
    "test:jsonl:node": "node --experimental-strip-types src/jsonl-consumer-node.ts",
    "test:sqlite:bun": "bun src/sqlite-wal-bun.ts",
    "test:sqlite:node": "node --experimental-strip-types src/sqlite-wal-node.ts",
    "build:compile": "bun build --compile --target=bun-darwin-arm64 --outfile=results/standalone src/standalone.ts",
    "test:sdk-imports": "bun src/sdk-imports.ts"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "latest",
    "@openai/codex-sdk": "latest",
    "better-sqlite3": "^11.8.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^22.10.6",
    "bun-types": "^1.3.12",
    "typescript": "^5.7.3"
  }
}
